---
const navLinks = [
  { label: "Home",       href: "/" },
  { label: "Gallery",    href: "/gallery" },
  { label: "Compare",    href: "/compare" },
  { label: "Contact Us", href: "/contact" },
];

const legalLinks = [
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Copyright",      href: "/copyright" },
];
---

<footer id="site-footer">
  <div class="footer-inner">
    <!-- Brand -->
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <img src="/favicon.png" alt="AshPhotoStudio" width="32" height="32" />
        <span class="font-display">AshPhotoStudio</span>
      </a>
      <p class="footer-tagline">
        Capturing life's most precious moments — from Mumbai to wherever your story takes us.
      </p>
      <!-- Social placeholders -->
      <div class="social-row">
        <a href="#" class="social-icon" aria-label="Instagram" title="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20"></rect>
            <circle cx="12" cy="12" r="5"></circle>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
          </svg>
        </a>
        <a href="#" class="social-icon" aria-label="Facebook" title="Facebook">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
        <a href="#" class="social-icon" aria-label="YouTube" title="YouTube">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.4a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"></path>
            <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"></polygon>
          </svg>
        </a>
        <a href="https://wa.me/919699766852" class="social-icon" aria-label="WhatsApp" title="WhatsApp" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="footer-col">
      <h3 class="footer-heading">Quick Links</h3>
      <ul>
        {navLinks.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div class="footer-col">
      <h3 class="footer-heading">Contact</h3>
      <ul class="contact-list">
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.33h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.09 6.09l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          <a href="tel:+919699766852">+91 96997 66852</a>
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          <a href="mailto:ashpaul102@email.com">ashpaul102@email.com</a>
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          <span>Churchgate, Mumbai, Maharashtra</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© 2026 AshPhotoStudio. All rights reserved.</p>
    <div class="legal-links">
      {legalLinks.map(link => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
  </div>
</footer>

<style>
  #site-footer {
    background: #111111;
    border-top: 1px solid #2a2a2a;
    margin-top: 6rem;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 2rem 2rem;
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 3rem;
  }

  /* Brand column */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: #ffffff;
    margin-bottom: 1rem;
  }

  .footer-logo img {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .footer-logo span {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: #a0a0a0;
    line-height: 1.7;
    max-width: 280px;
    margin-bottom: 1.5rem;
  }

  .social-row {
    display: flex;
    gap: 1rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid #2a2a2a;
    color: #a0a0a0;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .social-icon:hover {
    color: #ffffff;
    border-color: #555;
    background: #1a1a1a;
  }

  .social-icon svg {
    width: 18px;
    height: 18px;
  }

  /* Nav / contact columns */
  .footer-heading {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #ffffff;
    margin-bottom: 1.25rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid #2a2a2a;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-col a {
    font-size: 0.875rem;
    color: #a0a0a0;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: #ffffff;
  }

  /* Contact list */
  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.875rem;
    color: #a0a0a0;
  }

  .contact-list svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .contact-list span {
    line-height: 1.5;
  }

  /* Bottom bar */
  .footer-bottom {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    border-top: 1px solid #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: #555;
  }

  .legal-links {
    display: flex;
    gap: 1.25rem;
  }

  .legal-links a {
    font-size: 0.8rem;
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }

  .legal-links a:hover {
    color: #a0a0a0;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 580px) {
    .footer-inner {
      grid-template-columns: 1fr;
      padding: 3rem 1rem 1.5rem;
      gap: 2rem;
    }

    .footer-bottom {
      padding: 1rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>
