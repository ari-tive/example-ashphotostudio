---

<Layout
  title="Gallery — AshPhotoStudio"
  description="Browse Ash Paul's photography portfolio — weddings, honeymoons, pets, and architecture shoots in Mumbai and across India."
>
  <Header />

  <main class="gallery-page">
    <!-- Page heading -->
    <div class="gallery-hero">
      <p class="section-eyebrow">Portfolio</p>
      <h1 class="gallery-title font-display">GALLERY</h1>
      <p class="gallery-sub">
        A selection of work across weddings, honeymoons, pets, and architecture.
        Click any image to view full size.
      </p>
    </div>

    <!-- Carousel rows -->
    {categories.map((cat, catIdx) => (
      <div class="category-row">
        <div class="category-label-wrap">
          <span class="category-label">{cat.label}</span>
          <div class="category-line"></div>
        </div>

        <div class="carousel-wrapper" data-direction={cat.direction}>
          <!-- Track: images duplicated for seamless loop -->
          <div class={`carousel-track dir-${cat.direction}`} data-cat={catIdx}>
            {[...cat.images, ...cat.images].map((src, imgIdx) => (
              <button
                class="carousel-img-btn"
                aria-label={`View ${cat.label} photo ${(imgIdx % cat.images.length) + 1}`}
                data-src={src}
                data-cat-label={cat.label}
              >
                <img
                  src={src}
                  alt={`${cat.label} photography by Ash Paul`}
                  loading="lazy"
                  height="320"
                />
              </button>
            ))}
          </div>
        </div>
      </div>
    ))}
  </main>

  <!-- Lightbox -->
  <div id="lightbox" role="dialog" aria-modal="true" aria-label="Photo lightbox">
    <button id="lightbox-close" aria-label="Close lightbox">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <img id="lightbox-img" src="" alt="Full size photo" />
  </div>

  <Footer />
</Layout>

<style>
  .gallery-page {
    padding-top: 68px; /* header height */
  }

  /* Page hero */
  .gallery-hero {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 2rem 3rem;
  }

  .section-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #a0a0a0;
    margin-bottom: 0.5rem;
  }

  .gallery-title {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .gallery-sub {
    font-size: 1rem;
    color: #a0a0a0;
    max-width: 560px;
    line-height: 1.7;
  }

  /* Category rows */
  .category-row {
    margin-bottom: 3.5rem;
  }

  .category-label-wrap {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .category-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #ffffff;
    white-space: nowrap;
  }

  .category-line {
    flex: 1;
    height: 1px;
    background: #2a2a2a;
  }

  /* Carousel container */
  .carousel-wrapper {
    overflow: hidden;
    width: 100%;
    position: relative;
  }

  /* Gradient fade edges */
  .carousel-wrapper::before,
  .carousel-wrapper::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }

  .carousel-wrapper::before {
    left: 0;
    background: linear-gradient(to right, #0a0a0a, transparent);
  }

  .carousel-wrapper::after {
    right: 0;
    background: linear-gradient(to left, #0a0a0a, transparent);
  }

  /* Carousel track: set in global.css — just sizing here */
  .carousel-track {
    gap: 0.625rem;
  }

  .carousel-img-btn {
    display: block;
    flex-shrink: 0;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    height: 280px;
  }

  .carousel-img-btn img {
    height: 280px;
    width: auto;
    display: block;
    object-fit: cover;
    transition: transform 0.4s ease, filter 0.3s ease;
    border: 1px solid #1a1a1a;
  }

  .carousel-img-btn:hover img {
    transform: scale(1.04);
    filter: brightness(1.1);
  }

  /* Lightbox */
  #lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.94);
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
  }

  #lightbox.open {
    display: flex;
  }

  #lightbox img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border: 1px solid #2a2a2a;
  }

  #lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 44px;
    height: 44px;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    cursor: pointer;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  #lightbox-close:hover {
    background: #2a2a2a;
  }

  #lightbox-close svg {
    width: 20px;
    height: 20px;
  }

  @media (max-width: 640px) {
    .gallery-hero {
      padding: 2.5rem 1rem 2rem;
    }

    .category-label-wrap {
      padding: 0 1rem;
    }

    .carousel-img-btn,
    .carousel-img-btn img {
      height: 200px;
    }
  }
</style>

<script>
  // ── Lightbox ───────────────────────────────────────────────
  const lightbox = document.getElementById("lightbox") as HTMLDivElement;
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const closeBtn = document.getElementById("lightbox-close");

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    lightbox.classList.remove("open");
    document.body.style.overflow = "";
    // Clear src after transition
    setTimeout(() => { lightboxImg.src = ""; }, 200);
  }

  // Open on image click
  document.querySelectorAll<HTMLButtonElement>(".carousel-img-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const src = btn.dataset.src ?? "";
      const label = btn.dataset.catLabel ?? "Photo";
      openLightbox(src, `${label} photography by Ash Paul`);
    });
  });

  // Close handlers
  closeBtn?.addEventListener("click", closeLightbox);

  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox();
  });
</script>
